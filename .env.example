# Copy to ".env" in this folder (do not commit .env).

# OpenAI or compatible API:
OPENAI_API_KEY=

# Optional:
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# Ollama (local): after `ollama serve` and `ollama pull <model>`
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.2
